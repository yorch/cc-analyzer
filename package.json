{
  "name": "cc-analyzer",
  "version": "0.4.1",
  "description": "Read-only CLI to browse and analyze Claude Code sessions in ~/.claude",
  "engines": {
    "bun": ">=1.3.0"
  },
  "type": "module",
  "bin": {
    "cc-analyzer": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts && bun run scripts/embed-spa.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "bun run build:web && bun build --compile --outfile dist/cc-analyzer src/cli/index.ts"
  },
  "dependencies": {
    "hono": "4.12.28",
    "ink": "7.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@fontsource-variable/fraunces": "5.2.9",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "ink-testing-library": "4.0.0",
    "react-devtools-core": "7.0.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vite-plugin-singlefile": "2.3.3"
  }
}
